# Required
DATABASE_URL=postgres://gallery:gallery@localhost:5432/gallery?sslmode=disable
JWT_SECRET=change-me-to-a-random-secret

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/photos

# S3-compatible (when STORAGE_TYPE=s3)
# STORAGE_S3_BUCKET=my-gallery
# STORAGE_S3_ENDPOINT=https://s3.amazonaws.com
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=
# STORAGE_S3_PUBLIC=false

# Image processing
IMAGE_THUMB_WIDTH=400
IMAGE_MEDIUM_WIDTH=1200
IMAGE_FULL_WIDTH=2400

# Server
PORT=8080
MIGRATIONS_PATH=./migrations
